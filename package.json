  "version": "1.0.2",
  "description": "Obsidian plugin — DQL syntax highlighting for Dynatrace Query Language",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
